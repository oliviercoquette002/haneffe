<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Haneffe">
<meta name="theme-color" content="#2d6a4f">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icon.svg">
<title>Projet Haneffe</title>
<style>
:root{
  --green:#2d6a4f;--green-l:#e8f5ee;--green-t:#1a3d2e;
  --orange:#c45c00;--orange-l:#fff3e8;--orange-t:#7a3800;
  --red:#b91c1c;--red-l:#fef2f2;--red-t:#7f1d1d;
  --blue:#1d4ed8;--blue-l:#eff6ff;--blue-t:#1e3a8a;
  --bg:#f5f4f0;--surface:#fff;--s2:#f0efe9;--border:#e2e0d6;
  --text:#1a1a18;--text2:#5c5c52;--text3:#9b9a8e;
  --r:14px;--rs:8px;
  --safe-top:env(safe-area-inset-top,0px);
  --safe-bottom:env(safe-area-inset-bottom,0px);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden;background:var(--bg);font-family:-apple-system,'SF Pro Text',sans-serif;color:var(--text)}
.app{display:flex;flex-direction:column;height:100%;height:100dvh}
.topbar{background:var(--green);padding:calc(var(--safe-top)+12px) 16px 12px;flex-shrink:0;display:flex;align-items:center;gap:10px}
.topbar-icon{font-size:20px}
.topbar-text h1{font-size:15px;font-weight:700;color:#fff;letter-spacing:-.3px}
.topbar-text p{font-size:11px;color:rgba(255,255,255,.7);margin-top:1px}
.sync-bar{background:rgba(0,0,0,.18);padding:5px 16px;display:flex;align-items:center;gap:7px;font-size:11px;color:rgba(255,255,255,.9);flex-shrink:0}
.sync-dot{width:7px;height:7px;border-radius:50%;background:#4ade80;flex-shrink:0}
.sync-dot.pulse{animation:pulse 1s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:14px 16px 6px}
.bottomnav{background:var(--surface);border-top:1px solid var(--border);padding:8px 0 calc(var(--safe-bottom)+6px);display:flex;flex-shrink:0}
.navitem{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:4px 0;cursor:pointer;color:var(--text3)}
.navitem.active{color:var(--green)}
.navitem svg{width:22px;height:22px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.navitem span{font-size:10px;font-weight:500}
.page{display:none}.page.active{display:block}
.card{background:var(--surface);border-radius:var(--r);padding:15px;margin-bottom:12px;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.card-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--text3);margin-bottom:11px}
.metrics{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px}
.metric{background:var(--surface);border-radius:var(--r);padding:13px 14px;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.metric.warn{background:var(--orange-l)}.metric.danger{background:var(--red-l)}.metric.ok{background:var(--green-l)}
.mlabel{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px}
.mvalue{font-size:20px;font-weight:700;letter-spacing:-.5px}
.metric.warn .mvalue{color:var(--orange)}.metric.danger .mvalue{color:var(--red)}.metric.ok .mvalue{color:var(--green)}
.msub{font-size:10px;color:var(--text3);margin-top:1px}
.alert{border-radius:var(--rs);padding:11px 13px;font-size:13px;margin-bottom:10px;display:flex;gap:9px;line-height:1.5}
.alert.warn{background:var(--orange-l);color:var(--orange-t)}
.alert.ok{background:var(--green-l);color:var(--green-t)}
.alert.info{background:var(--blue-l);color:var(--blue-t)}
.aico{font-size:16px;flex-shrink:0}
.badge{display:inline-block;padding:3px 9px;border-radius:99px;font-size:11px;font-weight:600}
.b-ok{background:var(--green-l);color:var(--green-t)}.b-warn{background:var(--orange-l);color:var(--orange-t)}
.b-danger{background:var(--red-l);color:var(--red-t)}.b-grey{background:var(--s2);color:var(--text2)}
.b-blue{background:var(--blue-l);color:var(--blue-t)}.b-diy{background:#dcfce7;color:#166534}
.task-item{display:flex;align-items:flex-start;gap:12px;padding:13px 15px;border-bottom:1px solid var(--border);background:var(--surface)}
.task-item:first-child{border-radius:var(--r) var(--r) 0 0}
.task-item:last-child{border-bottom:none;border-radius:0 0 var(--r) var(--r)}
.task-check{width:22px;height:22px;border-radius:50%;border:2px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;cursor:pointer;margin-top:1px}
.task-check.done{background:var(--green);border-color:var(--green);color:#fff}
.task-body{flex:1;min-width:0}.task-title{font-size:14px;font-weight:500;line-height:1.4}
.task-title.done{text-decoration:line-through;color:var(--text3)}
.task-meta{font-size:12px;color:var(--text2);margin-top:3px}
.task-date{font-size:11px;color:var(--text3);flex-shrink:0;margin-top:3px}
.budget-item{padding:13px 15px;border-bottom:1px solid var(--border);background:var(--surface)}
.budget-item:first-child{border-radius:var(--r) var(--r) 0 0}
.budget-item:last-child{border-bottom:none;border-radius:0 0 var(--r) var(--r)}
.budget-item.tr-gap{background:#fff8f8}.budget-item.tr-new{background:#fffbf5}.budget-item.tr-diy{background:#f0fdf6}
.bi-name{font-size:14px;font-weight:500;margin-bottom:6px}
.bi-amounts{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:5px}
.bi-lbl{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.3px}
.bi-val{font-size:14px;font-weight:600}
.bi-ecart{font-size:12px;font-weight:600;padding:3px 8px;border-radius:99px}
.bi-ecart.neg{background:var(--red-l);color:var(--red-t)}.bi-ecart.pos{background:var(--green-l);color:var(--green-t)}
.section-hd{font-size:13px;font-weight:700;color:var(--green);margin:18px 0 8px;display:flex;align-items:center;gap:7px}
.phase-pill{background:var(--green);color:#fff;border-radius:99px;font-size:11px;padding:2px 9px}
.total-bar{background:var(--surface);border-radius:var(--r);padding:14px 15px;display:flex;justify-content:space-between;margin-bottom:12px;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.total-bar .lbl{font-size:12px;color:var(--text2);font-weight:500;margin-bottom:2px}
.total-bar .val{font-size:18px;font-weight:700}

/* ===== DEVIS ===== */
.scan-btn{background:var(--green);color:#fff;border:none;border-radius:var(--r);padding:18px 16px;width:100%;display:flex;align-items:center;justify-content:center;gap:10px;font-size:15px;font-weight:700;cursor:pointer;margin-bottom:16px;font-family:inherit;box-shadow:0 4px 14px rgba(45,106,79,.35)}
.scan-btn:active{opacity:.85}
.dcard{background:var(--surface);border-radius:var(--r);margin-bottom:12px;box-shadow:0 1px 3px rgba(0,0,0,.06);overflow:hidden}
.dcard-hd{padding:14px 15px;display:flex;justify-content:space-between;align-items:flex-start;cursor:pointer}
.dcard-name{font-size:15px;font-weight:700}
.dcard-sub{font-size:12px;color:var(--text2);margin-top:2px}
.dcard-amount{font-size:17px;font-weight:700;color:var(--green);text-align:right;white-space:nowrap}
.dcard-body{border-top:1px solid var(--border);padding:12px 15px;display:none}
.dcard-body.open{display:block}
.dl{display:flex;justify-content:space-between;gap:8px;padding:6px 0;border-bottom:1px solid var(--border);font-size:13px}
.dl:last-child{border-bottom:none}
.dl span:first-child{color:var(--text2);flex:1;line-height:1.4}
.dl span:last-child{font-weight:600;white-space:nowrap}
.dtotal{display:flex;justify-content:space-between;font-weight:700;font-size:15px;padding-top:10px;margin-top:6px;border-top:2px solid var(--border)}
.dnotes{font-size:12px;color:var(--text2);margin-top:10px;padding:8px 10px;background:var(--s2);border-radius:var(--rs);line-height:1.5}
.dactions{display:flex;gap:8px;margin-top:10px}
.dbtn{flex:1;padding:10px;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;border:none;font-family:inherit}
.dbtn-ok{background:var(--green-l);color:var(--green-t)}
.dbtn-no{background:var(--red-l);color:var(--red-t)}
.dbtn-del{background:var(--s2);color:var(--text2)}

/* ===== MODAL ===== */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:100;align-items:flex-end}
.modal-bg.open{display:flex}
.modal{background:var(--surface);border-radius:20px 20px 0 0;padding:20px 20px calc(var(--safe-bottom)+20px);width:100%;max-height:88vh;overflow-y:auto}
.mhandle{width:36px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 16px}
.mtitle{font-size:16px;font-weight:700;margin-bottom:16px}
.field{margin-bottom:14px}
.field label{font-size:12px;color:var(--text2);margin-bottom:5px;display:block;font-weight:500}
.field input,.field textarea,.field select{width:100%;border:1px solid var(--border);border-radius:10px;padding:10px 13px;font-size:15px;font-family:inherit;color:var(--text);background:var(--s2)}
.field input:focus,.field textarea:focus{border-color:var(--green);background:#fff;outline:none}
.field textarea{resize:none;min-height:70px;line-height:1.5}
.mbtns{display:flex;gap:8px;margin-top:6px}
.mbtns button{flex:1;padding:13px;border-radius:12px;font-size:15px;font-weight:600;cursor:pointer;border:none;font-family:inherit}
.mbtn-c{background:var(--s2);color:var(--text)}
.mbtn-s{background:var(--green);color:#fff}
.mbtn-d{background:var(--red-l);color:var(--red-t)}
.photo-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px}
.photo-opt{background:var(--s2);border:2px dashed var(--border);border-radius:var(--r);padding:22px 10px;text-align:center;cursor:pointer;font-size:13px;color:var(--text2);font-weight:500;-webkit-user-select:none}
.photo-opt:active{background:var(--green-l);border-color:var(--green)}
.photo-ico{font-size:30px;display:block;margin-bottom:8px}
.preview-img{width:100%;border-radius:var(--rs);margin-bottom:14px;max-height:220px;object-fit:cover;display:block}
.ai-box{text-align:center;padding:28px 16px}
.ai-spin{width:38px;height:38px;border:3px solid var(--border);border-top-color:var(--green);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 14px}
@keyframes spin{to{transform:rotate(360deg)}}
.ai-txt{font-size:13px;color:var(--text2);line-height:1.7}
.btn{border:1px solid var(--border);border-radius:20px;padding:8px 16px;font-size:13px;font-weight:500;cursor:pointer;background:var(--surface);color:var(--text);font-family:inherit}
.btn-g{background:var(--green);color:#fff;border-color:var(--green);width:100%;padding:13px;border-radius:12px;font-size:15px}
.btn-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
</style>
</head>
<body>
<div class="app">
  <div class="topbar">
    <div class="topbar-icon">🏠</div>
    <div class="topbar-text">
      <h1>Projet Haneffe</h1>
      <p>Oli &amp; Kri · Actes 18/08/2026</p>
    </div>
  </div>
  <div class="sync-bar">
    <div class="sync-dot" id="sdot"></div>
    <span id="slabel">Connexion...</span>
  </div>
  <div class="scroll" id="scroll-area">

    <!-- ACCUEIL -->
    <div class="page active" id="page-home">
      <div class="metrics" id="ov-metrics"></div>
      <div id="ov-alerts"></div>
      <div class="card-title" style="padding:0 2px 6px">🔑 Actions urgentes</div>
      <div id="actions-list" style="margin-bottom:12px"></div>
    </div>

    <!-- BUDGET -->
    <div class="page" id="page-budget">
      <div class="total-bar">
        <div><div class="lbl">Budget prévu</div><div class="val" id="tp">—</div></div>
        <div style="text-align:right"><div class="lbl">Réel / devis</div><div class="val" id="tr">—</div></div>
      </div>
      <div id="budget-list"></div>
      <button class="btn btn-g" style="margin-top:4px" onclick="openBModal()">+ Ajouter un poste</button>
    </div>

    <!-- PLANNING -->
    <div class="page" id="page-planning">
      <div id="planning-list"></div>
      <div class="btn-row">
        <button class="btn" onclick="openTModal(1)">+ Phase 1</button>
        <button class="btn" onclick="openTModal(2)">+ Phase 2</button>
        <button class="btn" onclick="openTModal(3)">+ Phase 3</button>
      </div>
    </div>

    <!-- DEVIS -->
    <div class="page" id="page-devis">
      <button class="scan-btn" onclick="openScan()">
        📸 &nbsp; Photographier un devis — l'IA l'analyse !
      </button>
      <div id="devis-list"></div>
    </div>

  </div>
  <nav class="bottomnav">
    <div class="navitem active" onclick="goPage('home',this)">
      <svg viewBox="0 0 24 24"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H5a1 1 0 01-1-1V9.5z"/><polyline points="9 21 9 12 15 12 15 21"/></svg>
      <span>Accueil</span>
    </div>
    <div class="navitem" onclick="goPage('budget',this)">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v1m0 8v1m-3.5-5H15"/></svg>
      <span>Budget</span>
    </div>
    <div class="navitem" onclick="goPage('planning',this)">
      <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      <span>Planning</span>
    </div>
    <div class="navitem" onclick="goPage('devis',this)">
      <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg>
      <span>Devis</span>
    </div>
  </nav>
</div>

<!-- MODAL SCAN -->
<div class="modal-bg" id="m-scan">
  <div class="modal">
    <div class="mhandle"></div>
    <div class="mtitle">📸 Analyser un devis</div>
    <div id="s1">
      <div class="photo-grid">
        <div class="photo-opt" onclick="document.getElementById('cam').click()">
          <span class="photo-ico">📷</span>Prendre une photo
        </div>
        <div class="photo-opt" onclick="document.getElementById('fil').click()">
          <span class="photo-ico">🖼️</span>Choisir une image
        </div>
      </div>
      <input type="file" id="cam" accept="image/*" capture="environment" style="display:none" onchange="onPhoto(this)">
      <input type="file" id="fil" accept="image/*" style="display:none" onchange="onPhoto(this)">
      <p style="font-size:12px;color:var(--text3);text-align:center;line-height:1.6">Photographiez n'importe quel devis — l'IA extrait automatiquement toutes les informations</p>
    </div>
    <div id="s2" style="display:none">
      <img id="prev" class="preview-img" src="" alt="">
      <div class="mbtns">
        <button class="mbtn-c" onclick="resetScan()">Rechoisir</button>
        <button class="mbtn-s" onclick="analyze()">🤖 Analyser avec l'IA</button>
      </div>
    </div>
    <div id="s3" style="display:none">
      <div class="ai-box">
        <div class="ai-spin"></div>
        <div class="ai-txt" id="ai-msg">L'IA analyse votre devis...</div>
      </div>
    </div>
    <div id="s4" style="display:none">
      <div class="alert ok" style="margin-bottom:14px"><span class="aico">✅</span><div>Analyse terminée ! Vérifiez et sauvegardez.</div></div>
      <div class="field"><label>Entreprise</label><input type="text" id="f-ent"></div>
      <div class="field"><label>N° Devis · Date</label><input type="text" id="f-num"></div>
      <div class="field"><label>Type de travaux</label><input type="text" id="f-trav"></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
        <div class="field"><label>HTVA (€)</label><input type="number" id="f-htva"></div>
        <div class="field"><label>TTC (€)</label><input type="number" id="f-ttc"></div>
      </div>
      <div class="field"><label>Postes principaux</label><textarea id="f-postes" style="min-height:90px"></textarea></div>
      <div class="field"><label>Points clés</label><textarea id="f-notes"></textarea></div>
      <div class="field"><label>Statut</label>
        <select id="f-statut"><option>À étudier</option><option>Accepté</option><option>Refusé</option><option>En attente</option></select>
      </div>
      <div class="mbtns">
        <button class="mbtn-c" onclick="closeM('m-scan')">Annuler</button>
        <button class="mbtn-s" onclick="saveDevis()">💾 Enregistrer</button>
      </div>
    </div>
  </div>
</div>

<!-- MODAL BUDGET -->
<div class="modal-bg" id="m-bud">
  <div class="modal">
    <div class="mhandle"></div>
    <div class="mtitle" id="mb-title">Nouveau poste</div>
    <div class="field"><label>Nom du poste</label><input type="text" id="mb-nom"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
      <div class="field"><label>Budget prévu (€)</label><input type="number" id="mb-prev" min="0"></div>
      <div class="field"><label>Réel / Devis (€)</label><input type="number" id="mb-reel" min="0"></div>
    </div>
    <div class="field"><label>Statut</label>
      <select id="mb-stat"><option>À faire</option><option>À devis</option><option>Devis reçu</option><option>Commandé</option><option>En cours</option><option>Terminé</option><option>À prévoir</option></select>
    </div>
    <div class="field"><label>Qui</label><input type="text" id="mb-qui"></div>
    <div class="field"><label>Commentaires</label><textarea id="mb-com"></textarea></div>
    <div class="mbtns">
      <button class="mbtn-c" onclick="closeM('m-bud')">Annuler</button>
      <button class="mbtn-d" id="mb-del" style="display:none" onclick="delBudget()">Supprimer</button>
      <button class="mbtn-s" onclick="saveBudget()">Enregistrer</button>
    </div>
  </div>
</div>

<!-- MODAL TACHE -->
<div class="modal-bg" id="m-task">
  <div class="modal">
    <div class="mhandle"></div>
    <div class="mtitle" id="mt-title">Nouvelle tâche</div>
    <div class="field"><label>Tâche</label><input type="text" id="mt-nom"></div>
    <div class="field"><label>Date</label><input type="text" id="mt-date" placeholder="ex: 22/08/2026"></div>
    <div class="field"><label>Statut</label>
      <select id="mt-stat"><option>À faire</option><option>En cours</option><option>Fait ✓</option><option>Reporté</option><option>Annulé</option></select>
    </div>
    <div class="field"><label>Qui</label><input type="text" id="mt-qui"></div>
    <div class="field"><label>Notes</label><textarea id="mt-com"></textarea></div>
    <div class="mbtns">
      <button class="mbtn-c" onclick="closeM('m-task')">Annuler</button>
      <button class="mbtn-d" id="mt-del" style="display:none" onclick="delTask()">Supprimer</button>
      <button class="mbtn-s" onclick="saveTask()">Enregistrer</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/gun/gun.js"></script>
<script>
// DONNÉES PAR DÉFAUT
const DA={
  actions:[
    {dl:"⚠️ Avant 20/06",a:"Valider/négocier les devis Fra Reno 001 & 002",s:"À faire"},
    {dl:"⚠️ Avant 20/06",a:"Verser acompte 40% = 5 251,56 € (BE93 7320 6854 1867)",s:"À faire"},
    {dl:"🔴 Urgent",a:"Relancer notaire — remise anticipée des clés (mail 29/05)",s:"À faire"},
    {dl:"🔴 Urgent",a:"Vérifier si mur chambre/chambre porteur → éco. ~998 €",s:"À faire"},
    {dl:"📋 Juin",a:"Devis aérogomage + mesures (prévu 08/06)",s:"À faire"},
    {dl:"📋 Juin",a:"Choix chassis / baies vitrées (09/06)",s:"À faire"},
    {dl:"📋 Juillet",a:"Réserver déménageur : Oli 22/08 + Kri 29/08",s:"À faire"},
    {dl:"📅 18/08/2026",a:"🔑 Signature des actes chez le notaire",s:"À faire"},
  ],
  budget:[
    {p:"Baies / ouvertures murs porteurs (Fra 001)",pv:9949,rl:9524.89,s:"Devis reçu",q:"Fra Reno",c:"Dans le budget ✓",t:"fra"},
    {p:"Électricité (Fra 002 — partiel)",pv:0,rl:3604,s:"Devis reçu",q:"Fra Reno",c:"Tableau + spots à chiffrer",t:"new"},
    {p:"Abattage mur chambre étage",pv:500,rl:0,s:"À faire",q:"DIY",c:"",t:"diy"},
    {p:"Reconstruction cloison étage",pv:500,rl:0,s:"À faire",q:"DIY",c:"",t:"diy"},
