// ÉTAT
let D={},eBi=-1,eTp=0,eTi=-1,photo64='',lastPush='';

function def(){return JSON.parse(JSON.stringify(DA));}
function load(){const s=localStorage.getItem('hpwa3');D=s?JSON.parse(s):def();if(!D.devis)D.devis=JSON.parse(JSON.stringify(DA.devis));}
function save(){localStorage.setItem('hpwa3',JSON.stringify(D));push();}

// GUN SYNC
const GKEY='haneffe-oli-kri-4357-v3';
let gun,gnode,gready=false;

function initGun(){
  try{
    gun=Gun(['https://peer.wallie.io/gun']);
    gnode=gun.get(GKEY);
    syncDot('wait');
    gnode.get('d').on(data=>{
      if(!data)return;
      try{
        if(data===lastPush)return;
        const r=JSON.parse(data);
        if(JSON.stringify(r)!==JSON.stringify(D)){D=r;if(!D.devis)D.devis=[];localStorage.setItem('hpwa3',data);renderAll();}
        syncDot('ok');gready=true;
      }catch(e){syncDot('ok');gready=true;}
    });
    setTimeout(()=>{if(!gready)syncDot('ok');},4000);
  }catch(e){syncDot('off');}
}

function push(){
  if(!gnode)return;
  const s=JSON.stringify(D);lastPush=s;
  syncDot('sync');
  gnode.get('d').put(s,a=>{syncDot(a.err?'err':'ok');});
}

function syncDot(st){
  const d=document.getElementById('sdot'),l=document.getElementById('slabel');
  if(!d||!l)return;
  d.className='sync-dot';d.style.background='';
  if(st==='ok'){d.style.background='#4ade80';l.textContent='Synchronisé avec Kristel ✓';}
  else if(st==='sync'){d.className='sync-dot pulse';d.style.background='#fbbf24';l.textContent='Synchronisation...';}
  else if(st==='wait'){d.className='sync-dot pulse';d.style.background='#fbbf24';l.textContent='Connexion...';}
  else{d.style.background='#9b9a8e';l.textContent='Mode hors ligne';}
}

// NAV
function goPage(n,el){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.navitem').forEach(x=>x.classList.remove('active'));
  document.getElementById('page-'+n).classList.add('active');
  el.classList.add('active');
  document.getElementById('scroll-area').scrollTop=0;
}

