  document.getElementById('ov-metrics').innerHTML=`
    <div class="metric"><div class="mlabel">Budget prévu</div><div class="mvalue">${Math.round(totP).toLocaleString('fr-BE')} €</div><div class="msub">total estimé</div></div>
    <div class="metric warn"><div class="mlabel">Devis Fra</div><div class="mvalue">13 129 €</div><div class="msub">TTC confirmés</div></div>
    <div class="metric danger"><div class="mlabel">Élec manquante</div><div class="mvalue">~3 604€+</div><div class="msub">non budgétée</div></div>
    <div class="metric ok"><div class="mlabel">Actes notaire</div><div class="mvalue" style="font-size:15px">18/08/2026</div><div class="msub">J−${jours} jours</div></div>
  `;
  document.getElementById('ov-alerts').innerHTML=`
    <div class="alert warn"><span class="aico">⚠️</span><div><strong>Acompte 40% avant le 20/06</strong> — 5 251,56 € sur BE93 7320 6854 1867</div></div>
    <div class="alert ok"><span class="aico">✅</span><div><strong>Baies dans le budget</strong> — Fra 001 (9 525€) vs budget (9 949€) ✓</div></div>
  `;
  document.getElementById('actions-list').innerHTML=D.actions.map((a,i)=>{
    const done=a.s==='Fait ✓';
    const bc=a.dl.includes('⚠️')||a.dl.includes('🔴')?'b-danger':a.dl.includes('📅')?'b-grey':'b-blue';
    const r=`border-radius:${i===0?'var(--r) var(--r) 0 0':i===D.actions.length-1?'0 0 var(--r) var(--r)':'0'}`;
    const bb=i===D.actions.length-1?'border-bottom:none':'';
    return`<div class="task-item" style="${r};${bb}" onclick="togAct(${i})">
      <div class="task-check ${done?'done':''}">${done?'✓':''}</div>
      <div class="task-body"><div class="task-title ${done?'done':''}">${a.a}</div>
      <div class="task-meta"><span class="badge ${bc}">${a.dl}</span></div></div>
    </div>`;
  }).join('');
}
function togAct(i){D.actions[i].s=D.actions[i].s==='Fait ✓'?'À faire':'Fait ✓';save();renderHome();}

// BUDGET
function fmt(n){return(parseFloat(n)||0).toLocaleString('fr-BE',{minimumFractionDigits:0,maximumFractionDigits:2})+' €';}
function renderBudget(){
  const totP=D.budget.reduce((s,r)=>s+(parseFloat(r.pv)||0),0);
  const totR=D.budget.reduce((s,r)=>s+(parseFloat(r.rl)||0),0);
  document.getElementById('tp').textContent=fmt(totP);
  document.getElementById('tr').textContent=totR>0?fmt(totR):'—';
  document.getElementById('budget-list').innerHTML=D.budget.map((r,i)=>{
    const p=parseFloat(r.pv)||0,rl=parseFloat(r.rl)||0,df=rl-p;
    let ec='';if(rl>0){ec=`<span class="bi-ecart ${df>0?'neg':'pos'}">${df>=0?'+':''}${fmt(df)}</span>`;}
    const tc=r.t==='new'?'tr-new':r.t==='diy'?'tr-diy':(rl>p&&p>0?'tr-gap':'');
    const tb=r.t==='diy'?'<span class="badge b-diy">DIY</span> ':r.t==='new'?'<span class="badge b-warn">Nouveau</span> ':r.t==='fra'?'<span class="badge b-ok">Fra</span> ':'';
    const sc=r.s==='Terminé'?'b-ok':r.s==='Devis reçu'?'b-blue':'b-grey';
    const rt=`border-radius:${i===0?'var(--r) var(--r) 0 0':i===D.budget.length-1?'0 0 var(--r) var(--r)':'0'}`;
    const bb=i===D.budget.length-1?'border-bottom:none':'';
    return`<div class="budget-item ${tc}" style="${rt};${bb}" onclick="openBModal(${i})">
      <div class="bi-name">${tb}${r.p}</div>
      <div class="bi-amounts">
        <div><div class="bi-lbl">Prévu</div><div class="bi-val" style="color:var(--text2)">${fmt(p)}</div></div>
        ${rl>0?`<div><div class="bi-lbl">Réel</div><div class="bi-val">${fmt(rl)}</div></div>`:''}
        ${ec}
      </div>
      <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap">
        <span class="badge ${sc}">${r.s}</span>
        ${r.q?`<span style="font-size:11px;color:var(--text3)">${r.q}</span>`:''}
        ${r.c?`<span style="font-size:11px;color:var(--text3)">${r.c}</span>`:''}
      </div>
    </div>`;
  }).join('');
}

function openBModal(i){
  eBi=i!==undefined?i:-1;
  const r=i!==undefined?D.budget[i]:{};
  document.getElementById('mb-title').textContent=i!==undefined?'Modifier':'Nouveau poste';
  document.getElementById('mb-nom').value=r.p||'';
  document.getElementById('mb-prev').value=r.pv||'';
  document.getElementById('mb-reel').value=r.rl||'';
  document.getElementById('mb-stat').value=r.s||'À faire';
  document.getElementById('mb-qui').value=r.q||'';
  document.getElementById('mb-com').value=r.c||'';
  document.getElementById('mb-del').style.display=i!==undefined?'block':'none';
  openM('m-bud');
}
function saveBudget(){
  const row={p:document.getElementById('mb-nom').value||'Poste',pv:parseFloat(document.getElementById('mb-prev').value)||0,rl:parseFloat(document.getElementById('mb-reel').value)||0,s:document.getElementById('mb-stat').value,q:document.getElementById('mb-qui').value,c:document.getElementById('mb-com').value,t:eBi>=0?D.budget[eBi].t:'n'};
  if(eBi>=0)D.budget[eBi]=row;else D.budget.push(row);
  save();closeM('m-bud');renderBudget();
}
function delBudget(){if(eBi>=0)D.budget.splice(eBi,1);save();closeM('m-bud');renderBudget();}

// PLANNING
function renderPlanning(){
  const phases=[{n:1,l:'Préparation du déménagement',items:D.p1},{n:2,l:'Installation & emménagement',items:D.p2},{n:3,l:'Travaux après emménagement',items:D.p3}];
  document.getElementById('planning-list').innerHTML=phases.map(ph=>`
    <div class="section-hd"><div class="phase-pill">Phase ${ph.n}</div> ${ph.l}</div>
    ${ph.items.map((r,i)=>{
      const done=r.s==='Fait ✓';
      const sc=done?'b-ok':r.s==='En cours'?'b-blue':'b-grey';
      const isO=ph.items.length===1;
      const rt=`border-radius:${isO?'var(--r)':i===0?'var(--r) var(--r) 0 0':i===ph.items.length-1?'0 0 var(--r) var(--r)':'0'}`;
      const bb=isO||i===ph.items.length-1?'border-bottom:none':'';
      const pb=ph.n===3&&r.pr?`<span class="badge ${r.pr==='Haute'?'b-danger':'b-warn'}">${r.pr}</span> `:'';
      return`<div class="task-item" style="${rt};${bb}" onclick="openTModal(${ph.n},${i})">
        <div class="task-check ${done?'done':''}" onclick="event.stopPropagation();togTask(${ph.n},${i})">${done?'✓':''}</div>
        <div class="task-body"><div class="task-title ${done?'done':''}">${r.t}</div>
        <div class="task-meta">${pb}<span class="badge ${sc}">${r.s}</span>${r.q?` <span style="font-size:11px;color:var(--text3)">${r.q}</span>`:''}</div></div>
        <div class="task-date">${r.d}</div>
      </div>`;
    }).join('')}
  `).join('');
}
function togTask(ph,i){const k='p'+ph;D[k][i].s=D[k][i].s==='Fait ✓'?'À faire':'Fait ✓';save();renderPlanning();}

function openTModal(ph,i){
  eTp=ph;eTi=i!==undefined?i:-1;
  const k='p'+ph;const r=i!==undefined?D[k][i]:{};
  document.getElementById('mt-title').textContent=i!==undefined?'Modifier la tâche':`Nouvelle tâche — Phase ${ph}`;
  document.getElementById('mt-nom').value=r.t||'';
  document.getElementById('mt-date').value=r.d||'';
  document.getElementById('mt-stat').value=r.s||'À faire';
  document.getElementById('mt-qui').value=r.q||'';
  document.getElementById('mt-com').value=r.c||'';
  document.getElementById('mt-del').style.display=i!==undefined?'block':'none';
  openM('m-task');
}
function saveTask(){
  const k='p'+eTp;
  const row={t:document.getElementById('mt-nom').value||'Tâche',d:document.getElementById('mt-date').value||'?',s:document.getElementById('mt-stat').value,q:document.getElementById('mt-qui').value,c:document.getElementById('mt-com').value};
  if(eTp===3)row.pr=D[k][eTi]?.pr||'Moyenne';
  if(eTi>=0)D[k][eTi]=row;else D[k].push(row);
  save();closeM('m-task');renderPlanning();
}
function delTask(){if(eTi>=0)D['p'+eTp].splice(eTi,1);save();closeM('m-task');renderPlanning();}

// DEVIS
function renderDevis(){
  const list=document.getElementById('devis-list');
  if(!D.devis||!D.devis.length){list.innerHTML='<div style="text-align:center;padding:30px;color:var(--text3);font-size:14px">Appuyez sur le bouton vert pour analyser votre premier devis !</div>';return;}
  list.innerHTML=D.devis.map((d,i)=>{
    const sc=d.st==='Accepté'?'b-ok':d.st==='Refusé'?'b-danger':d.st==='En attente'?'b-blue':'b-grey';
    const postes=(d.postes||'').split('\n').filter(x=>x.trim()).map(x=>`<div class="dl"><span>${x}</span><span></span></div>`).join('');
    return`<div class="dcard">
      <div class="dcard-hd" onclick="togD(${i})">
        <div style="flex:1;min-width:0">
          <div class="dcard-name">${d.ent}</div>
          <div class="dcard-sub">${d.num}</div>
          <div style="margin-top:5px"><span class="badge ${sc}">${d.st}</span> <span style="font-size:11px;color:var(--text2)">${d.trav}</span></div>
        </div>
        <div style="margin-left:10px">
          <div class="dcard-amount">${fmt(d.ttc)}</div>
          <div style="font-size:10px;color:var(--text3);text-align:right">TTC</div>
        </div>
      </div>
      <div class="dcard-body" id="db-${i}">
        ${postes}
        <div class="dtotal"><span>TOTAL TTC</span><span style="color:var(--green)">${fmt(d.ttc)}</span></div>
        ${d.notes?`<div class="dnotes">📋 ${d.notes}</div>`:''}
        <div class="dactions">
          <button class="dbtn dbtn-ok" onclick="setDSt(${i},'Accepté')">✅ Accepter</button>
          <button class="dbtn dbtn-no" onclick="setDSt(${i},'Refusé')">❌ Refuser</button>
          <button class="dbtn dbtn-del" onclick="delD(${i})">🗑️</button>
        </div>
      </div>
    </div>`;
  }).join('');
}
function togD(i){document.getElementById('db-'+i).classList.toggle('open');}
function setDSt(i,s){D.devis[i].st=s;save();renderDevis();}
function delD(i){if(confirm('Supprimer ce devis ?')){D.devis.splice(i,1);save();renderDevis();}}

// SCAN
const MSGS=['🔍 Lecture du devis...','💶 Extraction des montants...','📋 Identification des postes...','✅ Finalisation...'];
let mInt;

function openScan(){resetScan();openM('m-scan');}
function resetScan(){
  photo64='';
  ['s1','s2','s3','s4'].forEach((id,i)=>document.getElementById(id).style.display=i===0?'block':'none');
  document.getElementById('cam').value='';document.getElementById('fil').value='';
}
function onPhoto(inp){
  const f=inp.files[0];if(!f)return;
  const r=new FileReader();
  r.onload=e=>{
    photo64=e.target.result.split(',')[1];
    document.getElementById('prev').src=e.target.result;
    document.getElementById('s1').style.display='none';
    document.getElementById('s2').style.display='block';
  };
  r.readAsDataURL(f);
}
async function analyze(){
  document.getElementById('s2').style.display='none';
  document.getElementById('s3').style.display='block';
  let mi=0;
  mInt=setInterval(()=>{document.getElementById('ai-msg').textContent=MSGS[mi++%MSGS.length];},1800);
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        system:'Expert devis travaux belges. Réponds UNIQUEMENT en JSON valide sans markdown.',
        messages:[{role:'user',content:[
          {type:'image',source:{type:'base64',media_type:'image/jpeg',data:photo64}},
          {type:'text',text:'Analyse ce devis et retourne exactement ce JSON:\n{"ent":"nom entreprise","num":"numéro · date","trav":"type travaux court","htva":0,"ttc":0,"postes":"ligne1\\nligne2\\nligne3","notes":"conditions importantes"}'}
        ]}]
      })
    });
    const data=await res.json();
    clearInterval(mInt);
    const parsed=JSON.parse(data.content[0].text.replace(/```json|```/g,'').trim());
    document.getElementById('f-ent').value=parsed.ent||'';
    document.getElementById('f-num').value=parsed.num||'';
    document.getElementById('f-trav').value=parsed.trav||'';
    document.getElementById('f-htva').value=parsed.htva||'';
    document.getElementById('f-ttc').value=parsed.ttc||'';
    document.getElementById('f-postes').value=parsed.postes||'';
    document.getElementById('f-notes').value=parsed.notes||'';
    document.getElementById('s3').style.display='none';
    document.getElementById('s4').style.display='block';
  }catch(e){
    clearInterval(mInt);
    document.getElementById('ai-msg').innerHTML='❌ Erreur. Vérifiez que la photo est nette et réessayez.';
    setTimeout(resetScan,2500);
  }
}
function saveDevis(){
  if(!D.devis)D.devis=[];
  D.devis.push({
    id:Date.now(),
    ent:document.getElementById('f-ent').value,
    num:document.getElementById('f-num').value,
    trav:document.getElementById('f-trav').value,
    htva:parseFloat(document.getElementById('f-htva').value)||0,
    ttc:parseFloat(document.getElementById('f-ttc').value)||0,
    st:document.getElementById('f-statut').value,
    postes:document.getElementById('f-postes').value,
    notes:document.getElementById('f-notes').value,
  });
  save();closeM('m-scan');renderDevis();
}

// MODALS
function openM(id){document.getElementById(id).classList.add('open');document.body.style.overflow='hidden';}
function closeM(id){document.getElementById(id).classList.remove('open');document.body.style.overflow='';}
document.querySelectorAll('.modal-bg').forEach(bg=>bg.addEventListener('click',e=>{if(e.target===bg)closeM(bg.id);}));

// INIT
function renderAll(){renderHome();renderBudget();renderPlanning();renderDevis();}
if('serviceWorker' in navigator)navigator.serviceWorker.register('/haneffe/sw.js').catch(()=>{});
load();renderAll();initGun();
</script>
